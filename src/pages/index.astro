---
import BaseLayout from '../layouts/BaseLayout.astro';

const blogPages = Object.values(import.meta.glob('./*.mdx', { eager: true })) as any[];
const articles = blogPages
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const categories = [...new Set(articles.map(a => a.frontmatter.category))];
---

<BaseLayout
  title="Blog Shortmotion | Vidéo short, montage et réseaux sociaux"
  description="Conseils, guides et astuces pour créer des vidéos courtes qui convertissent. Par Shortmotion, service de montage vidéo pro livré en 48h."
>
  <section class="hero">
    <h1>Blog</h1>
    <p>Nos conseils pour créer des vidéos short qui convertissent</p>
  </section>

  <section class="categories">
    <button class="cat-btn active" data-category="all">Tous</button>
    {categories.map(cat => (
      <button class="cat-btn" data-category={cat}>{cat}</button>
    ))}
  </section>

  <section class="articles-grid">
    {articles.map((article) => (
      <a href={article.url} class="article-card" data-category={article.frontmatter.category}>
        <div class="card-cover">
          <img src={article.frontmatter.image} alt={article.frontmatter.title} loading="lazy" />
        </div>
        <div class="card-content">
          <div class="card-meta">
            <time datetime={article.frontmatter.date}>
              {new Date(article.frontmatter.date).toLocaleDateString('fr-FR', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <span>·</span>
            <span>{article.frontmatter.readTime}</span>
          </div>
          <h2>{article.frontmatter.title}</h2>
          <p>{article.frontmatter.description}</p>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = btn.getAttribute('data-category');
      document.querySelectorAll('.article-card').forEach(card => {
        if (cat === 'all' || card.getAttribute('data-category') === cat) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.125rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .categories {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .cat-btn {
    background: var(--bg-card);
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }

  .cat-btn:hover, .cat-btn.active {
    background: #111111;
    color: #ffffff;
    border-color: #111111;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    padding-bottom: 4rem;
  }

  .article-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.25s;
    display: block;
    overflow: hidden;
  }

  .article-card:hover {
    border-color: #d1d5db;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .card-cover {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 12px;
    margin: 0.5rem;
  }

  .card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .article-card:hover .card-cover img {
    transform: scale(1.03);
  }

  .card-content {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .article-card h2 {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.35rem;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .article-card p {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2rem 0 2rem;
    }

    .articles-grid {
      grid-template-columns: 1fr;
    }

    .card-cover {
      aspect-ratio: 16 / 10;
    }
  }
</style>
