---
import BaseLayout from '../layouts/BaseLayout.astro';

const blogPages = Object.values(import.meta.glob('./*.mdx', { eager: true })) as any[];
const articles = blogPages
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const categories = [...new Set(articles.map(a => a.frontmatter.category))];
---

<BaseLayout
  title="Blog Shortmotion — Vidéo courte, montage & réseaux sociaux"
  description="Conseils, guides et astuces pour créer des vidéos courtes qui convertissent. Par Shortmotion, service de montage vidéo pro livré en 48h."
>
  <section class="hero">
    <h1>Blog</h1>
    <p>Nos conseils pour créer des vidéos courtes qui convertissent</p>
  </section>

  <section class="categories">
    <button class="cat-btn active" data-category="all">Tous</button>
    {categories.map(cat => (
      <button class="cat-btn" data-category={cat}>{cat}</button>
    ))}
  </section>

  <section class="articles-grid">
    {articles.map((article, i) => {
      const colors = [
        { bg: '#f0f0f0', accent: '#111' },
        { bg: '#eef2ff', accent: '#4338ca' },
        { bg: '#fef3c7', accent: '#92400e' },
        { bg: '#ecfdf5', accent: '#065f46' },
        { bg: '#fce7f3', accent: '#9d174d' },
        { bg: '#e0f2fe', accent: '#0369a1' },
      ];
      const color = colors[i % colors.length];
      return (
        <a href={article.url} class="article-card" data-category={article.frontmatter.category}>
          <div class="card-cover" style={`background: ${color.bg};`}>
            <span class="cover-category" style={`color: ${color.accent};`}>{article.frontmatter.category}</span>
            <span class="cover-title" style={`color: ${color.accent};`}>{article.frontmatter.title}</span>
            <span class="cover-badge">Shortmotion</span>
            <span class="cover-read">{article.frontmatter.readTime}</span>
          </div>
          <div class="card-content">
            <div class="card-meta">
              <time datetime={article.frontmatter.date}>
                {new Date(article.frontmatter.date).toLocaleDateString('fr-FR', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <span>{article.frontmatter.readTime}</span>
            </div>
            <h2>{article.frontmatter.title}</h2>
            <p>{article.frontmatter.description}</p>
          </div>
        </a>
      );
    })}
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = btn.getAttribute('data-category');
      document.querySelectorAll('.article-card').forEach(card => {
        if (cat === 'all' || card.getAttribute('data-category') === cat) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.125rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .categories {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .cat-btn {
    background: var(--bg-card);
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }

  .cat-btn:hover, .cat-btn.active {
    background: #111111;
    color: #ffffff;
    border-color: #111111;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    padding-bottom: 4rem;
  }

  .article-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.25s;
    display: block;
    overflow: hidden;
  }

  .article-card:hover {
    border-color: #d1d5db;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .card-cover {
    position: relative;
    padding: 2rem 2rem 2.5rem;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border-radius: 12px;
    margin: 0.5rem;
    overflow: hidden;
  }

  .cover-category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
    opacity: 0.7;
  }

  .cover-title {
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1.25;
    letter-spacing: -0.02em;
    max-width: 90%;
  }

  .cover-badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: inherit;
    opacity: 0.4;
    letter-spacing: 0.04em;
  }

  .cover-read {
    position: absolute;
    bottom: 1.25rem;
    right: 1.25rem;
    font-size: 0.75rem;
    font-weight: 500;
    opacity: 0.5;
  }

  .card-content {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .article-card h2 {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.35rem;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .article-card p {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2rem 0 2rem;
    }

    .articles-grid {
      grid-template-columns: 1fr;
    }

    .card-cover {
      min-height: 180px;
    }

    .cover-title {
      font-size: 1.15rem;
    }
  }
</style>
